generator client {
  provider = "prisma-client-js"
  engine   = "prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id             String           @id @default(cuid())
  email          String           @unique
  name           String
  password       String?
  role           String           @default("student")
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  interviews     Interview[]
  moduleProgress ModuleProgress[]
  progress       Progress?
  userAnswers    UserAnswer[]

  @@index([email])
}

model Module {
  id          String           @id @default(cuid())
  title       String           @unique
  description String
  order       Int              @unique
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  concepts    Concept[]
  interviews  Interview[]
  progress    ModuleProgress[]
  questions   Question[]

  @@index([order])
}

model Concept {
  id          String   @id @default(cuid())
  title       String
  description String
  content     String?
  order       Int
  moduleId    String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  module      Module   @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  @@index([moduleId])
}

model Question {
  id            String         @id @default(cuid())
  title         String
  description   String
  type          QuestionType
  moduleId      String
  difficulty    String         @default("Medium")
  order         Int?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  codeChallenge CodeChallenge?
  mcqOptions    MCQOption[]
  module        Module         @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  userAnswers   UserAnswer[]

  @@index([moduleId])
  @@index([type])
}

model MCQOption {
  id         String   @id @default(cuid())
  text       String
  isCorrect  Boolean
  order      Int
  questionId String
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@index([questionId])
}

model CodeChallenge {
  id          String   @id @default(cuid())
  title       String
  language    String   @default("cpp")
  boilerplate String?
  testCases   Json
  questionId  String   @unique
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  question    Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
}

model UserAnswer {
  id             String   @id @default(cuid())
  userId         String
  questionId     String
  selectedOption String?
  code           String?
  output         String?
  isCorrect      Boolean
  score          Int      @default(0)
  createdAt      DateTime @default(now())
  question       Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, questionId])
  @@index([userId])
}

model ModuleProgress {
  id                 String    @id @default(cuid())
  userId             String
  moduleId           String
  completed          Boolean   @default(false)
  completedAt        DateTime?
  score              Int       @default(0)
  questionsAttempted Int       @default(0)
  questionsCorrect   Int       @default(0)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  module             Module    @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  user               User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, moduleId])
  @@index([userId])
  @@index([moduleId])
}

model Progress {
  id                      String   @id @default(cuid())
  userId                  String   @unique
  totalQuestionsAttempted Int      @default(0)
  totalCorrect            Int      @default(0)
  overallScore            Int      @default(0)
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt
  user                    User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Interview {
  id          String          @id @default(cuid())
  userId      String
  moduleId    String
  status      InterviewStatus @default(PENDING)
  score       Int?
  feedback    String?
  startedAt   DateTime?
  completedAt DateTime?
  qnaLog      Json            @default("[]")
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  module      Module          @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([moduleId])
  @@index([status])
}

enum QuestionType {
  MCQ
  CODE
}

enum InterviewStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  ABANDONED
}
